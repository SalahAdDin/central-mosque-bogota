{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@i18n/*": ["./src/i18n/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@styles/*": ["./src/styles/*"],
      "@storybook/*": ["./.storybook/*"],
      "@utils/*": ["./src/utils/*"],
      "@/*": ["./src/*"]
    },
    "types": ["vitest/globals"],
    "verbatimModuleSyntax": true
  },
  "include": [".astro/types.d.ts", "**/*", ".storybook/**/*"],
  "exclude": ["dist"]
}
