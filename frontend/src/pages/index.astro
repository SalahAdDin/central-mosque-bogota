---
import Layout from '@layouts/Layout.astro'
import HeroHijri from '@components/layout/HeroHijri.astro'
import DailyPrayerTime from '@components/data/display/DailyPrayTime/DailyPrayTime.astro'
import CommunityServicesSection from '@components/data/display/CommunityServicesSection/CommunityServicesSection.astro'
import AcademyCoursesSection from '@components/data/display/Academy/AcademyCoursesSection/AcademyCoursesSection.astro'
import NextEventsSection from '@components/data/display/Events/NextEventsSection/NextEventsSection.astro'
import MediaHighlightsSection from '@components/data/display/Media/MediaHighlightsSection/MediaHighlightsSection.astro'
import { getLangFromUrl, useTranslations } from '@i18n/utils'
import DonationImpactSection from '@components/data/display/Donations/DonationImpactSection/DonationImpactSection.astro'
import {
  academyCourses,
  defaultServices,
  events,
  featuredDonation,
  mediaHighlights,
} from '@utils/data.mocks'
import { getLiveEntry } from 'astro:content'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const { entry, error } = await getLiveEntry('prayerTimes', {
  languageCode: lang,
})

// TODO: rafactor to get default values from entry
const { times, location, hijriDate, currentDate } = entry!.data || {};
---

<Layout>
  <HeroHijri
    imageUrl="https://lh3.googleusercontent.com/aida-public/AB6AXuDdlrd8AprY013bVQSvLjSWaOwTysETvmudIyet1ui8bdnFC2mjZ1b5okpi2OJ9rqogESejmF4lJRn8efBrCuCrJcxw9DU7VIr03J1sT4lIhkty48r2AqpqaH069FoNZ5-xcE2ZXPcFDt2HXcaLaHtFY5swEUTuMeikRCAw6RFG_iB1VLOJMmIOLxfFbwudkXDYHFbFajgfAC6WR6QPpMCSmvGVwiv1G7w56_9SUpKGblDJo4l4GYZLxuc-WOiJFjPnUpSaZYKovL4"
    imageAlt="Beautiful Mosque Architecture"
    hijriDate={hijriDate}
    currentDate={currentDate}
    phrase="Unidos en oración y comunidad. Bienvenidos al corazón de la espiritualidad islámica en Bogotá."
  />
  <DailyPrayerTime
    location={location}
    hijriDate={hijriDate}
    currentDate={currentDate}
    schedule={times}
  />
  <CommunityServicesSection
    title={t('services.community-services')}
    services={defaultServices}
  />
  {
    academyCourses.length > 0 && (
      <AcademyCoursesSection
        title={t('academy.home-title')}
        description={t('academy.home-description')}
        ctaLabel={t('academy.home-cta-label')}
        articleCtaLabel={t('academy.article-cta-label')}
        academyHref="/academy"
        articles={academyCourses.map(courses => ({
          ...courses,
          ctaLabel: t('academy.article-cta-label'),
        }))}
      />
    )
  }
  {
    events.length > 0 && (
      <NextEventsSection
        title={t('events.next-events')}
        description={t('events.join-us')}
        ctaLabel={t('events.see-calendar')}
        events={events}
      />
    )
  }
  {
    mediaHighlights.length > 0 && (
      <MediaHighlightsSection
        title={t('media-highlights.title')}
        description={t('media-highlights.description')}
        cardCtaLabel={t('media-highlights.cta-card')}
        ctaLabel={t('media-highlights.cta')}
        mediaHref="/media"
        highlights={mediaHighlights}
      />
    )
  }
  {featuredDonation && <DonationImpactSection {...featuredDonation} />}
</Layout>
