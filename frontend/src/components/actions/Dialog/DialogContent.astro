---
import type { HTMLAttributes } from 'astro/types'

import { cn } from '@utils/styles.utils'

import {
  dialogBackdropVariants,
  dialogContentVariants,
  dialogCloseButtonVariants,
  type DialogContentVariants,
} from './variants'
import Icon from '@components/data/display/Icon.astro'
import { getLangFromUrl, useTranslations } from '@i18n/utils'

/**
 * @component DialogContent
 * @title Dialog Content
 * @description Native `<dialog>` element styled and wired for open/close state, with an optional backdrop slot and a built-in close button.
 *
 * @preview
 *
 * <Dialog>
 *   <DialogTrigger class="rounded-md border px-3 py-2">Open</DialogTrigger>
 *   <DialogContent>
 *     <DialogHeader>
 *       <DialogTitle>Example</DialogTitle>
 *       <DialogDescription>Short description</DialogDescription>
 *     </DialogHeader>
 *     <div class="py-4">Content</div>
 *     <DialogFooter>
 *       <DialogClose class="rounded-md border px-3 py-2">Close</DialogClose>
 *     </DialogFooter>
 *   </DialogContent>
 * </Dialog>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import {
 *   Dialog,
 *   DialogClose,
 *   DialogContent,
 *   DialogDescription,
 *   DialogFooter,
 *   DialogHeader,
 *   DialogTitle,
 *   DialogTrigger,
 * } from "@components/actions/Dialog";
 * ---
 *
 * <Dialog>
 *   <DialogTrigger class="rounded-md border px-3 py-2">Open</DialogTrigger>
 *   <DialogContent animationDuration={200}>
 *     <DialogHeader>
 *       <DialogTitle>Title</DialogTitle>
 *       <DialogDescription>Description</DialogDescription>
 *     </DialogHeader>
 *     <div class="py-4">Your dialog content goes here.</div>
 *     <DialogFooter>
 *       <DialogClose class="rounded-md border px-3 py-2">Close</DialogClose>
 *     </DialogFooter>
 *   </DialogContent>
 * </Dialog>
 * ```
 *
 * Notes:
 * - The `id` attribute can be used with `DialogTrigger target="..."` to open a specific dialog.
 * - The default close button can be hidden with CSS by targeting `[data-dialog-close]` inside this component.
 */

interface Props extends HTMLAttributes<'dialog'>, DialogContentVariants {
  /**
   * Open and close animation duration in milliseconds
   */
  animationDuration?: number
}

const {
  class: className,
  animationDuration = 200,
  ...rest
} = Astro.props as Props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang);
---
<!-- dialog overlay -->
<slot name="backdrop">
  <div
    class={dialogBackdropVariants()}
    data-dialog-backdrop
    data-state="closed"
    data-slot="dialog-backdrop"
    style={{ animationDuration: `${animationDuration}ms` }}
  >
  </div>
</slot>

<dialog
  class={cn(dialogContentVariants(), className)}
  style={{ animationDuration: `${animationDuration}ms` }}
  {...rest}
  data-dialog-content
  data-state="closed"
  data-slot="dialog-content"
>
  <slot />
  <button
    type="button"
    class={dialogCloseButtonVariants()}
    data-dialog-close
    aria-label={t('dialog.close')}
  >
    <slot name="icon">
      <Icon icon="close" class="size-5 transition-opacity" />
    </slot>
    <span class="sr-only">{t('sheet.close')}</span>
  </button>
</dialog>

<style>
  .dialog-content {
    --nested-offset: 1rem;
    --nested-scale: 0.05;
  }
</style>
