---
import DownloadPDF from './DownloadPDF.astro';
---

<div class="flex flex-col gap-6 p-6">
  <DownloadPDF documentTitle="Calendario de Oración" />

  <section
    data-document-prayer-calendar-table
    class="rounded-lg border border-slate-200 bg-white p-4 text-slate-900"
  >
    <header class="flex items-center justify-between gap-4">
      <h2 class="text-lg font-bold">Calendario de Oración</h2>
      <span class="text-sm text-slate-600">Bogotá D.C.</span>
    </header>

    <div class="mt-4 overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b">
            <th class="px-3 py-2 text-left font-semibold">Fecha</th>
            <th class="px-3 py-2 text-left font-semibold">Fajr</th>
            <th class="px-3 py-2 text-left font-semibold">Amanecer</th>
            <th class="px-3 py-2 text-left font-semibold">Dhuhr</th>
            <th class="px-3 py-2 text-left font-semibold">Asr</th>
            <th class="px-3 py-2 text-left font-semibold">Maghrib</th>
            <th class="px-3 py-2 text-left font-semibold">Isha</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b">
            <td class="px-3 py-2">12 de marzo</td>
            <td class="px-3 py-2">04:52</td>
            <td class="px-3 py-2">06:01</td>
            <td class="px-3 py-2">12:09</td>
            <td class="px-3 py-2">15:17</td>
            <td class="px-3 py-2">18:13</td>
            <td class="px-3 py-2">19:21</td>
          </tr>
          <tr>
            <td class="px-3 py-2">13 de marzo</td>
            <td class="px-3 py-2">04:53</td>
            <td class="px-3 py-2">06:01</td>
            <td class="px-3 py-2">12:09</td>
            <td class="px-3 py-2">15:17</td>
            <td class="px-3 py-2">18:13</td>
            <td class="px-3 py-2">19:21</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</div>
