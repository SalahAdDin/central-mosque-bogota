---
import { cn } from '@utils/styles.utils'
import type { HTMLAttributes } from 'astro/types'
import {
  dropdownTriggerVariants,
  type DropdownTriggerVariants,
} from './variants'

/**
 * @component DropdownTrigger
 * @title Dropdown Trigger
 * @description Button that toggles a dropdown menu. Must be used inside `Dropdown`.
 *
 * @preview
 *
 * <Dropdown>
 *   <DropdownTrigger class="rounded-md border px-3 py-2">Open</DropdownTrigger>
 *   <DropdownContent>
 *     <DropdownItem>Profile</DropdownItem>
 *   </DropdownContent>
 * </Dropdown>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import { Dropdown, DropdownContent, DropdownItem, DropdownTrigger } from "@components/actions/Dropdown";
 * ---
 *
 * <Dropdown>
 *   <DropdownTrigger>Open</DropdownTrigger>
 *   <DropdownContent>
 *     <DropdownItem>Profile</DropdownItem>
 *   </DropdownContent>
 * </Dropdown>
 * ```
 *
 * @examples
 *
 * ### Custom trigger element (asChild)
 *
 * ```astro nocollapse
 * ---
 * import Button from "@components/actions/Button/Button.astro";
 * import { Dropdown, DropdownContent, DropdownItem, DropdownTrigger } from "@components/actions/Dropdown";
 * ---
 *
 * <Dropdown>
 *   <DropdownTrigger asChild>
 *     <Button>Open</Button>
 *   </DropdownTrigger>
 *   <DropdownContent align="start">
 *     <DropdownItem>Option 1</DropdownItem>
 *   </DropdownContent>
 * </Dropdown>
 * ```
 */

interface Props
  extends
  DropdownTriggerVariants,
  Omit<HTMLAttributes<'button'>, 'role' | 'type'> {
  /**
   * When true, the component will render its child element with a simple wrapper instead of a button component
   */
  asChild?: boolean
}

const { class: className, asChild = false, ...rest } = Astro.props

// Get the first child element if asChild is true
let hasChildren = false

if (Astro.slots.has('default')) {
  hasChildren = true
}
---

{
  asChild && hasChildren
    ? (
        <div class={className} data-dropdown-trigger data-dropdown-as-child>
          <slot />
        </div>
      )
    : (
        <button
          type="button"
          class={cn(dropdownTriggerVariants(), className)}
          data-dropdown-trigger
          aria-haspopup="true"
          aria-expanded="false"
          {...rest}
        >
          <slot />
        </button>
      )
}
