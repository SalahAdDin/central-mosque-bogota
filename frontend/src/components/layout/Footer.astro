---
import Icon from '@components/data/display/Icon.astro'
import Link from '@components/actions/Link/Link.astro'
import Button from '@components/actions/Button.astro'
import SvgIcon from '@components/data/display/SvgIcon.astro'
import { getLangFromUrl, useTranslations } from '@i18n/utils'
import type { TSVGIcon, TNavLink } from '@utils/types'

type ContactInfo = {
  address: string
  phone: string
  email: string
}

type RightsTexts = {
  copyRight: string
  privacyPolicy: TNavLink
  termsAndConditions: TNavLink
}

interface Props {
  lemma?: string
  socialNetworkLinks?: Array<TNavLink & { icon: TSVGIcon }>
  fastLinks?: Array<TNavLink>
  contactInfo: ContactInfo
  rightsText: RightsTexts
}

const {
  lemma,
  socialNetworkLinks = [],
  fastLinks = [],
  contactInfo,
  rightsText,
} = Astro.props as Props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const hasContent = Boolean(
  lemma || socialNetworkLinks.length > 0 || fastLinks.length > 0 || rightsText,
)

if (!hasContent) {
  throw new Error(
    'Footer requires at least one of lemma, socialNetworkLinks, fastLinks or rightsText.',
  )
}
---

<footer class="bg-secondary pt-20 pb-10 text-white">
  <section
    class="
      mx-auto grid max-w-7xl grid-cols-1 gap-12 border-b border-white/10 px-4
      pb-16
      sm:px-6
      md:grid-cols-4
      lg:px-8
    "
  >
    <div class="
      col-span-1
      md:col-span-1
    "
    >
      <!-- Mosque branding -->
      <div class="mb-6 flex items-center gap-3">
        <div class="rounded-full bg-white px-3 py-1.5">
          <Icon name="mosque" class="text-3xl text-secondary" />
        </div>
        <div>
          <span class="block text-xl/tight font-bold tracking-tight">
            Mezquita Central
          </span>
          <span class="text-xs tracking-widest uppercase opacity-80">
            de Bogotá
          </span>
        </div>
      </div>
      <!-- Mosque lemma -->
      {lemma && <p class="mb-6 leading-relaxed text-blue-100/70">{lemma}</p>}
      <!-- Mosque social networks -->
      <ul class="flex gap-4">
        {
          socialNetworkLinks.map(({ label, href, icon }) => (
            <li>
              <Link
                class="
                  flex size-10 items-center justify-center rounded-full
                  bg-white/10
                  hover:bg-primary
                "
                href={href}
                aria-label={label}
              >
                <SvgIcon name={icon} class="size-5 fill-current" />
              </Link>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="col-span-1">
      <h4 class="mb-6 text-lg font-bold">{t('footer.quick-links')}</h4>
      <ul class="space-y-4 text-blue-100/70">
        {
          fastLinks.map(({ label, href }) => (
            <li>
              <Link href={href} color="navbar">
                {label}
              </Link>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="col-span-1">
      <h4 class="mb-6 text-lg font-bold">{t('footer.contact')}</h4>
      <ul class="space-y-4 text-blue-100/70">
        <li class="flex items-center gap-3">
          <Icon
            name="location_on"
            class="items-baseline text-sm text-blue-400"
          />
          <address class="not-italic">{contactInfo.address}</address>
        </li>
        <li class="flex items-center gap-3">
          <Icon name="phone" class="text-sm text-blue-400" />
          <phone>{contactInfo.phone}</phone>
        </li>
        <li class="flex items-center gap-3">
          <Icon name="email" class="text-sm text-blue-400" />
          <email>{contactInfo.email}</email>
        </li>
      </ul>
    </div>
    <div class="col-span-1">
      <h4 class="mb-6 text-lg font-bold">{t('footer.newsletter')}</h4>
      <p class="mb-4 text-sm text-blue-100/70">
        {t('footer.newsletter-description')}
      </p>
      <form class="flex flex-col gap-2">
        <input
          class="
            rounded-lg border-white/20 bg-white/10 px-4 py-2 text-sm text-white
            placeholder-blue-100/30
            focus:ring-2 focus:ring-secondary focus:outline-none
          "
          placeholder={t('footer.email-placeholder')}
          type="email"
        />
        <Button color="primary" type="submit" variant="solid">
          {t('footer.subscribe')}
        </Button>
      </form>
    </div>
  </section>
  <section
    class="
      mx-auto mt-10 flex max-w-7xl flex-col justify-between px-4 text-sm
      text-blue-100/40
      sm:px-6
      md:flex-row md:items-center
      lg:px-8
    "
  >
    <p>{rightsText?.copyRight}</p>
    <div
      class="
        mt-4 flex flex-col justify-between gap-4
        sm:flex-row
        md:mt-0 md:gap-6
      "
    >
      <Link color="navbar" href={rightsText?.privacyPolicy.href}>
        {rightsText?.privacyPolicy.label}
      </Link>
      <Link color="navbar" href={rightsText?.termsAndConditions.href}>
        {rightsText?.termsAndConditions.label}
      </Link>
    </div>
  </section>
</footer>
