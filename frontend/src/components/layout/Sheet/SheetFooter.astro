---
import { cn } from '@utils/styles.utils'
import type { HTMLAttributes } from 'astro/types'

/**
 * @component SheetFooter
 * @title Sheet Footer
 * @description Footer section for `SheetContent`. Sticks to the bottom via `mt-auto` and provides consistent padding for actions.
 *
 * @preview
 *
 * <SheetContent>
 *   <SheetFooter>
 *     <SheetClose class="rounded-md border px-3 py-2">Close</SheetClose>
 *   </SheetFooter>
 * </SheetContent>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import { SheetFooter, SheetClose } from "@components/layout/Sheet";
 * ---
 *
 * <SheetFooter>
 *   <SheetClose class="rounded-md border px-3 py-2">Close</SheetClose>
 * </SheetFooter>
 * ```
 */

interface Props extends HTMLAttributes<'footer'> {}

const { class: className, ...rest } = Astro.props;
---

<footer class={cn('mt-auto flex flex-col gap-2 p-4', className)} {...rest}>
  <slot />
</footer>
