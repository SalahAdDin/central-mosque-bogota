---
import type { HTMLAttributes } from 'astro/types'
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@utils/styles.utils'

/**
 * @component Icon
 * @title Icon
 * @description A wrapper around the Material Symbols font for rendering icons.
 * @figmaUrl https://www.figma.com/design/koxai7zw5vIuBzuVxe5T2l/bejamas-ui
 *
 * @preview
 *
 * <div class="flex flex-wrap items-center gap-3">
 *   <Icon name="menu" />
 *   <Icon name="search" />
 *   <Icon name="chevron_right" />
 * </div>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import Icon from "@components/data/display/Icons/Icon.astro";
 * ---
 *
 * <Icon name="menu" ariaLabel="Open navigation" />
 * ```
 *
 * @examples
 *
 * ### Sizes
 *
 * <div class="flex items-center gap-3">
 *   <Icon name="call" size="xs" />
 *   <Icon name="call" size="sm" />
 *   <Icon name="call" size="md" />
 *   <Icon name="call" size="lg" />
 *   <Icon name="call" size="xl" />
 * </div>
 *
 * ### Variants
 *
 * <div class="flex items-center gap-3">
 *   <Icon name="star" variant="outlined" />
 *   <Icon name="star" variant="rounded" />
 *   <Icon name="star" variant="sharp" />
 * </div>
 *
 * ### Decorative vs. labelled
 *
 * <div class="flex flex-col gap-2">
 *   <Icon name="arrow_forward" />
 *   <Icon name="arrow_forward" ariaLabel="Continue to next step" />
 * </div>
 */
const iconVariants = cva('items-center justify-center', {
  variants: {
    size: {
      xs: 'text-xs',
      sm: 'text-sm',
      md: 'text-base',
      lg: 'text-lg',
      xl: 'text-xl',
    },
    variant: {
      outlined: 'material-symbols-outlined',
      rounded: 'material-symbols-rounded',
      sharp: 'material-symbols-sharp',
    },
  },
  defaultVariants: {
    size: 'md',
    variant: 'outlined',
  },
})

interface Props
  extends VariantProps<typeof iconVariants>, HTMLAttributes<'span'> {
  /**
   * Name of the Material Symbols glyph to render, e.g. "menu" or "search".
   */
  name: string
  /**
   * Accessible label for the icon. When omitted, the icon is treated as decorative.
   */
  ariaLabel?: string
}

const {
  name,
  size,
  variant,
  class: className,
  ariaLabel,
  ...rest
} = Astro.props as Props

const isDecorative = !ariaLabel;
---

<span
  class={cn(iconVariants({ size, variant }), className)}
  aria-hidden={isDecorative || undefined}
  aria-label={ariaLabel}
  {...rest}
>
  {name}
</span>
