---
import Icon from '@components/data/display/Icons/Icon.astro'

/**
 * @component MediaHighlightCard
 * @title Media Highlight Card
 * @description A square media highlight teaser with background image, hover grayscale effect, title overlay, and a play CTA label.
 *
 * Notes
 * - Renders as an anchor (`<a>`) so the whole card is clickable.
 * - Designed for use inside `MediaHighlightsSection`.
 *
 * @preview
 *
 * <div class="max-w-xs">
 *   <MediaHighlightCard
 *     title="La importancia de leer el Sagrado Corán"
 *     href="/media/podcast-1"
 *     imageUrl="https://images.unsplash.com/photo-1548013146-72479768bada?auto=format&fit=crop&w=1200&q=80"
 *     imageAlt="Podcast cover"
 *     ctaLabel="Escuchar ahora"
 *   />
 * </div>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import MediaHighlightCard from "@components/data/display/Media/MediaHighlightsSection/MediaHighlightCard.astro";
 * ---
 *
 * <MediaHighlightCard
 *   title="El Valor de las 5 Oraciones Diarias"
 *   href="/media/podcast-2"
 *   imageUrl="/images/podcast-2.jpg"
 *   imageAlt="Podcast 2 cover"
 *   ctaLabel="Escuchar ahora"
 * />
 * ```
 */
interface Props {
  /**
   * Card title
   */
  title: string
  /**
   * Card href (link destination)
   */
  href: string
  /**
   * Background image URL
   */
  imageUrl: string
  /**
   * Background image alt text
   */
  imageAlt: string
  /**
   * Call-to-action label
   */
  ctaLabel: string
}

const { title, href, imageUrl, imageAlt, ctaLabel } = Astro.props as Props;
---

<a
  href={href}
  class="
    group relative block aspect-square cursor-pointer overflow-hidden
    rounded-2xl shadow-lg
  "
>
  <img
    alt={imageAlt}
    class="
      absolute inset-0 size-full object-cover grayscale transition-all
      duration-700
      group-hover:grayscale-0
    "
    src={imageUrl}
  />
  <div
    class="
      absolute inset-0 bg-black/40 transition-all
      group-hover:bg-black/20
    "
  >
  </div>
  <div class="absolute inset-x-6 top-6">
    <h3 class="text-xl/snug font-bold text-white uppercase">{title}</h3>
  </div>
  <div class="absolute bottom-6 left-6 flex items-center gap-2">
    <div
      class="flex size-8 items-center justify-center rounded-full bg-primary"
    >
      <Icon name="play_arrow" class="text-sm text-white" />
    </div>
    <span class="text-xs font-bold tracking-widest text-white uppercase">
      {ctaLabel}
    </span>
  </div>
</a>
