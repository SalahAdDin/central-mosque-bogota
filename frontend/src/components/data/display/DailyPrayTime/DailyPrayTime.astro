---
import Icon from '@components/data/display/Icons/Icon.astro'
import type { TDailyPrayerSchedule } from '@utils/models/types'
import { getLangFromUrl, useTranslations } from '@i18n/utils'
import { formatTime } from '@utils/time.utils'
import Link from '@components/actions/Link/Link.astro'

/**
 * @component DailyPrayTime
 * @title Daily Prayer Times
 * @description Daily prayer-time summary card. Renders a 6-item grid (Fajr, Sunrise, Dhuhr, Asr, Maghrib, Isha) plus location and dates.
 *
 * Active prayer highlight
 * - The currently active fard prayer is highlighted client-side via `daily-pray-time.controller.ts`.
 * - Sunrise is informational and is never treated as an active prayer.
 * - If the current time falls into a prohibited (no-prayer) window (after sunrise, around zawāl, or just before maghrib),
 *   nothing is highlighted.
 *
 * Data contract (used by the controller)
 * - Root: `[data-prayer-schedule]`
 * - Root datasets:
 *   - `data-timezone`: IANA timezone (defaults to America/Bogota)
 *   - `data-sunrise`: HH:mm sunrise time (optional but recommended for post-sunrise prohibition)
 * - Items:
 *   - `[data-prayer-item]` with `data-prayer` (key) and `data-time` (HH:mm)
 *   - `[data-prayer-label]` inside the item (label text node)
 *
 * i18n keys
 * - Title: `pray-schedule.title`
 * - Labels: `pray-schedule.{fajr|sunrise|dhuhr|asr|maghrib|isha}`
 *
 * @preview
 *
 * <DailyPrayTime
 *   location="Bogotá D.C., Colombia"
 *   hijriDate="15 Dhu al-Qi'dah"
 *   currentDate="25 de Mayo, 2024"
 *   timeZone="America/Bogota"
 *   schedule={{
 *     fajr: "05:40",
 *     sunrise: "06:15",
 *     dhuhr: "12:00",
 *     asr: "15:40",
 *     maghrib: "18:20",
 *     isha: "20:40",
 *   }}
 * />
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import DailyPrayTime from "@components/data/display/DailyPrayTime/DailyPrayTime.astro";
 * ---
 *
 * <DailyPrayTime
 *   location="Bogotá D.C., Colombia"
 *   hijriDate="Ramadán 1445 H"
 *   currentDate="10 Mar 2026"
 *   schedule={{
 *     fajr: "05:00",
 *     sunrise: "05:35",
 *     dhuhr: "12:05",
 *     asr: "15:25",
 *     maghrib: "18:10",
 *     isha: "19:30",
 *   }}
 * />
 * ```
 *
 * Notes:
 * - `schedule` values should be `HH:mm` strings; `formatTime()` is applied for display.
 * - If you omit `sunrise`, the sunrise row can still render (if provided by your schedule),
 *   but the post-sunrise prohibited window cannot be evaluated.
 */

interface Props {
  /**
   * Location label shown next to the location icon (display-only).
   */
  location: string
  /**
   * Hijri date label shown in the header (display-only).
   */
  hijriDate: string
  /**
   * Gregorian date label shown in the header (display-only).
   */
  currentDate: string
  /**
   * Prayer time schedule as HH:mm strings.
   *
   * Expected keys:
   * - `fajr`, `dhuhr`, `asr`, `maghrib`, `isha`
   * - `sunrise` is used for display and for the post-sunrise prohibited window (recommended).
   */
  schedule: TDailyPrayerSchedule
  /**
   * IANA timezone used by the controller when determining "now".
   * Defaults to America/Bogota.
   */
  timeZone?: string
}

const {
  location = 'Bogotá D.C., Colombia',
  hijriDate,
  currentDate,
  schedule,
  timeZone = 'America/Bogota',
} = Astro.props as Props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const PRAYER_ITEMS = [
  { key: 'fajr', label: t('pray-schedule.fajr') },
  { key: 'sunrise', label: t('pray-schedule.sunrise') },
  { key: 'dhuhr', label: t('pray-schedule.dhuhr') },
  { key: 'asr', label: t('pray-schedule.asr') },
  { key: 'maghrib', label: t('pray-schedule.maghrib') },
  { key: 'isha', label: t('pray-schedule.isha') },
] as const

const items = PRAYER_ITEMS.map(({ key, label }) => ({
  key,
  label,
  time: formatTime(schedule[key as keyof TDailyPrayerSchedule]),
}));
---

<section
  class="relative z-20 mx-auto -mt-40 max-w-5xl px-4"
  data-prayer-schedule
  data-timezone={timeZone}
  data-sunrise={schedule.sunrise ?? ''}
>
  <div
    class="
      flex flex-col items-center gap-8 rounded-2xl border border-slate-100
      bg-white p-6 shadow-2xl
      md:flex-row md:p-8
      dark:border-slate-700 dark:bg-slate-800
    "
  >
    <div class="
      w-full text-center
      md:w-1/3 md:text-left
    "
    >
      <div
        class="
          mb-2 flex items-center justify-center gap-2 font-semibold
          text-secondary
          md:justify-start
          dark:text-primary
        "
      >
        <Icon name="location_on" class="text-sm" />
        {location}
      </div>
      <h3 class="mb-1 text-2xl font-bold">
        {t('pray-schedule.title')}
        <!-- TODO: ensure the page does exist in CMS -->
        <Link
          href="/how-to-calculate-pray-times"
          class="text-sm text-slate-400"
          ariaLabel={t('pray-schedule.how-to-calculate')}
        >
          <Icon name="help" class="text-sm" />
        </Link>
      </h3>
      <p class="
        text-sm text-slate-500
        dark:text-slate-400
      "
      >
        {currentDate} • {hijriDate}
      </p>
    </div>
    <ul class="
      grid w-full flex-1 grid-cols-3 gap-4
      md:grid-cols-6
    "
    >
      {
        items.map(item => (
          <li
            class:list={[
              `
                flex flex-col items-center justify-center rounded-xl bg-slate-50
                p-3 text-center transition-all duration-300
                dark:bg-slate-700/50
              `,
              'data-prayer-item-active:text-white',
              'data-prayer-item-active:shadow-lg',
              'data-prayer-item-active:ring-4',
              'data-prayer-item-active:bg-secondary',
              'dark:data-prayer-item-active:bg-primary',
              'data-prayer-item-active:ring-secondary/20',
              'dark:data-prayer-item-active:ring-primary/20',
              'data-prayer-item-active:scale-105',
            ]}
            data-prayer-item
            data-prayer={item.key}
            data-time={item.time}
          >
            <p
              class:list={[
                `
                  text-[8px] tracking-widest text-ellipsis whitespace-nowrap
                  text-slate-400 uppercase
                  sm:text-[10px]
                `,
                'data-prayer-label-active:text-white/70',
                'mb-1 font-bold transition-colors duration-300',
              ]}
              data-prayer-label
            >
              {item.label}
            </p>
            <time
              class="
                text-sm font-bold
                sm:text-lg
              "
            >
              {item.time}
            </time>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  import { initDailyPrayerTimes } from "./daily-pray-time.controller";

  const setup = () => initDailyPrayerTimes();

  document.addEventListener("DOMContentLoaded", setup);
  document.addEventListener("astro:after-swap", setup);
</script>
