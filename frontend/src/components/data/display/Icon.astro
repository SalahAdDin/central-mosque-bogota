---
import { cva, type VariantProps } from "class-variance-authority";

import { cn } from "@utils/styles.utils";

/**
 * @component Icon
 * @title Icon
 * @description A wrapper around the Material Symbols font for rendering icons.
 * @figmaUrl https://www.figma.com/design/koxai7zw5vIuBzuVxe5T2l/bejamas-ui
 *
 * @preview
 *
 * <div class="flex flex-wrap items-center gap-3">
 *   <Icon icon="menu" />
 *   <Icon icon="search" />
 *   <Icon icon="chevron_right" />
 * </div>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import Icon from "@components/data/display/Icon.astro";
 * ---
 *
 * <Icon icon="menu" ariaLabel="Open navigation" />
 * ```
 *
 * @examples
 *
 * ### Sizes
 *
 * <div class="flex items-center gap-3">
 *   <Icon icon="call" size="xs" />
 *   <Icon icon="call" size="sm" />
 *   <Icon icon="call" size="md" />
 *   <Icon icon="call" size="lg" />
 *   <Icon icon="call" size="xl" />
 * </div>
 *
 * ### Variants
 *
 * <div class="flex items-center gap-3">
 *   <Icon icon="star" variant="outlined" />
 *   <Icon icon="star" variant="rounded" />
 *   <Icon icon="star" variant="sharp" />
 * </div>
 *
 * ### Decorative vs. labelled
 *
 * <div class="flex flex-col gap-2">
 *   <Icon icon="arrow_forward" />
 *   <Icon icon="arrow_forward" ariaLabel="Continue to next step" />
 * </div>
 */
const iconVariants = cva("items-center justify-center", {
  variants: {
    size: {
      xs: "text-xs",
      sm: "text-sm",
      md: "text-base",
      lg: "text-lg",
      xl: "text-xl",
    },
    variant: {
      outlined: "material-symbols-outlined",
      rounded: "material-symbols-rounded",
      sharp: "material-symbols-sharp",
    },
  },
  defaultVariants: {
    size: "md",
    variant: "outlined",
  },
});

interface Props extends VariantProps<typeof iconVariants> {
  /**
   * Name of the Material Symbols glyph to render, e.g. "menu" or "search".
   */
  icon: string;
  /**
   * Accessible label for the icon. When omitted, the icon is treated as decorative.
   */
  ariaLabel?: string;
  /**
   * Extra Tailwind classes applied to the icon wrapper element.
   */
  class?: string;
  /**
   * Any additional attributes are forwarded to the underlying <span>.
   * Useful for id, data-* attributes, and event handlers.
   */
  [key: string]: any;
}

const {
  icon,
  size,
  variant,
  class: className,
  ariaLabel,
  ...rest
} = Astro.props as Props;

const isDecorative = !ariaLabel;
---

<span
  class={cn(iconVariants({ size, variant }), className)}
  aria-hidden={isDecorative || undefined}
  aria-label={ariaLabel}
  {...rest}
>
  {icon}
</span>
