---
import Link from '@components/actions/Link/Link.astro'
import Icon from '@components/data/display/Icons/Icon.astro'
import { getLangFromUrl, useTranslations } from '@i18n/utils'
import type { TEvent } from '@utils/models/events'

/**
 * @component EventVerticalCard
 * @title Event Vertical Card
 * @description A vertical event teaser card with image, category, title, description, schedule, and a "see more" link.
 *
 * Notes:
 * - The call-to-action label is localized via `useTranslations(getLangFromUrl(Astro.url))`.
 * - The image and date badge are currently static in this component; pass content via props for the text fields.
 *
 * @preview
 *
 * <div class="max-w-sm">
 *   <EventVerticalCard
 *     category="Educación"
 *     title="Clase de Caligrafía Árabe"
 *     description="Aprende los fundamentos de la caligrafía y practica estilos tradicionales."
 *     schedule="Sábados · 10:00"
 *   />
 * </div>
 *
 * @usage
 *
 * ```astro nocollapse
 * ---
 * import EventVerticalCard from "@components/data/display/Events/EventVerticalCard/EventVerticalCard.astro";
 * ---
 *
 * <EventVerticalCard
 *   category="Conferencia"
 *   title="Charla: Introducción al Islam"
 *   description="Una sesión abierta para resolver dudas y conocer los pilares de la fe."
 *   schedule="Viernes · 18:00"
 * />
 * ```
 */

interface Props extends Omit<TEvent, 'location'> {}

const { category, title, description, schedule, date, image, url }
  = Astro.props as Props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang);
---

<article
  class="
    group overflow-hidden rounded-xl border border-secondary/5 bg-white
    shadow-sm transition-all
    hover:shadow-xl
  "
>
  <div class="relative h-56 overflow-hidden">
    <img
      class="
        size-full object-cover transition-transform duration-500
        group-hover:scale-105
      "
      data-alt={title}
      alt={title}
      src={image}
    />
    <div
      class="
        absolute top-4 right-4 flex min-w-[60px] flex-col items-center
        rounded-lg bg-primary p-3 text-white shadow-lg
      "
    >
      <span class="text-xs font-bold tracking-tighter uppercase">
        {date.month}
      </span>
      <span class="text-2xl font-black">{date.day}</span>
    </div>
  </div>
  <div class="p-6">
    <div class="mb-3 flex items-center gap-2 text-sm font-bold text-primary">
      <Icon name="school" class="text-xs" />
      {category}
    </div>
    <h3
      class="
        mb-3 text-2xl/tight font-bold text-secondary transition-colors
        group-hover:text-primary
      "
    >
      {title}
    </h3>
    <p class="mb-6 text-sm/relaxed text-secondary/60">
      {description}
    </p>
    <div
      class="flex items-center justify-between border-t border-secondary/5 pt-4"
    >
      <div
        class="flex items-center gap-2 text-xs font-semibold text-secondary/40"
      >
        <Icon name="schedule" class="text-sm" />
        {schedule}
      </div>
      <Link
        href={url}
        color="secondary"
        class="
          font-bold
          hover:gap-2
        "
      >
        {t('see-more')}
        <Icon name="arrow_forward" class="text-sm" />
      </Link>
    </div>
  </div>
</article>
