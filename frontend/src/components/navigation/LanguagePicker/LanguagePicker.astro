---
import {
  Dropdown,
  DropdownContent,
  DropdownTrigger,
} from '@components/actions/Dropdown'
import Icon from '@components/data/display/Icons/Icon.astro'
import { languages, localeFlags, routes, type TLang } from '@i18n/ui'
import { getLangFromUrl, isSupportedLang, useTranslations } from '@i18n/utils'
import type { TDropdownAlign, TDropdownPosition } from '@utils/models/types'

// TODO: https://github.com/starwind-ui/starwind-ui/issues/135
interface Props {
  /**
   * Position of the dropdown menu relative to its trigger element.
   * @default bottom
   */
  side?: TDropdownPosition
  /**
   * Alignment of the dropdown menu relative to its trigger element.
   * @default end
   */
  align?: TDropdownAlign
}

const { side = 'bottom', align = 'end' } = Astro.props as Props

const currentLang = getLangFromUrl(Astro.url)
const t = useTranslations(currentLang)

const url = Astro.url
const parts = url.pathname.split('/').filter(Boolean)
const langFromPath = parts[0]
const rest = isSupportedLang(langFromPath) ? parts.slice(1) : parts

const buildLangHref = (targetLang: TLang): string => {
  const suffix = `${url.search}${url.hash}`

  if (rest.length === 0) {
    return `/${targetLang}/${suffix}`
  }

  if (rest.length === 1) {
    const slug = rest[0]
    const entries = Object.entries(routes[currentLang])
    const match = entries.find(([, value]) => value === slug)
    const fallbackKey = slug in routes[currentLang] ? slug : undefined
    const canonicalKey = match?.[0] ?? fallbackKey

    if (canonicalKey) {
      const localizedSlug = routes[targetLang][canonicalKey] ?? canonicalKey
      return `/${targetLang}/${localizedSlug}${suffix}`
    }

    return `/${targetLang}/${slug}${suffix}`
  }

  return `/${targetLang}/${rest.join('/')}${suffix}`
};
---

<Dropdown>
  <DropdownTrigger
    aria-label={t('language-picker.label')}
    class="
      flex items-center gap-1.5 rounded-lg bg-white/10 px-3 py-2 text-sm
      font-bold text-white transition-all
      hover:bg-white/20
      focus-visible:ring-2 focus-visible:ring-slate-500
      focus-visible:ring-offset-2 focus-visible:outline-none
      dark:bg-slate-900 dark:text-slate-50
      [&[aria-expanded='true']_[data-language-chevron]]:rotate-180
    "
  >
    <Icon name="language" class="text-[18px]" />
    <span>{currentLang.toUpperCase()}</span>
    <Icon
      name="expand_more"
      class="
        text-[16px] opacity-60 transition-transform duration-150
        motion-reduce:transition-none
      "
      data-language-chevron
    />
  </DropdownTrigger>
  <!-- TODO: calculate align and side based on the picker position -->
  <DropdownContent
    align={align}
    side={side}
    sideOffset={8}
    class="
      w-44 overflow-hidden rounded-xl border border-slate-100 bg-white py-2
      text-slate-900 shadow-xl
      dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50
    "
  >
    {
      localeFlags.map(({ code, flag }) => (
        <a
          href={buildLangHref(code)}
          class="
            flex cursor-pointer items-center gap-3 px-4 py-2 text-sm
            font-semibold text-slate-700 transition-colors
            hover:bg-slate-200
            focus-visible:bg-slate-50
            motion-reduce:cursor-default
            dark:text-slate-200
            dark:hover:bg-white/20
            dark:focus-visible:bg-slate-800
          "
          aria-current={code === currentLang ? 'page' : undefined}
          role="menuitem"
          tabindex="0"
          data-dropdown-item
        >
          <span
            class="
              flex h-4 w-5 shrink-0 items-center justify-center rounded-sm
              bg-slate-200 text-[10px]
              dark:bg-slate-700
            "
          >
            {flag}
          </span>
          <span>{languages[code]}</span>
        </a>
      ))
    }
  </DropdownContent>
</Dropdown>
