{
  "name": "frontend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "build-storybook": "storybook build",
    "dev": "astro dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "cd .. && husky ./frontend/.husky",
    "preview": "astro preview",
    "storybook": "storybook dev -p 6006",
