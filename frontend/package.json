    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.12",
